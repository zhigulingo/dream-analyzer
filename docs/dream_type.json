{
    "dream_type_classification": {
      "meta": {
        "version": "1.0",
        "description": "Формат определения типа сна: Память / Эмоция / Предвосхищение",
        "author": "DreamsTalk AI",
        "date": "2025-10-10"
      },
  
      "axes": {
        "context_axis": {
          "title": "Контекст (временная связь)",
          "description": "Определяет, связан ли сюжет сна с недавними событиями, знакомыми людьми или новыми ситуациями.",
          "indicators": {
            "memory": [
              "упоминание знакомых людей",
              "места из реальности",
              "повтор недавних событий",
              "дневные ассоциации (работа, дом, школа)"
            ],
            "emotion": [
              "неясный или абстрактный сюжет",
              "дезориентация",
              "хаотичность сцены"
            ],
            "anticipation": [
              "новые места или испытания",
              "будущие события (экзамен, выступление, переезд)",
              "тема ожидания, подготовки, тренировки"
            ]
          },
          "weight": 0.33
        },
  
        "emotion_axis": {
          "title": "Эмоции",
          "description": "Оценивает силу и характер чувств, проявленных во сне.",
          "metrics": {
            "emotional_density": "доля эмоционально окрашенных слов",
            "valence": "положительная / отрицательная направленность",
            "intensity": "низкая / средняя / высокая"
          },
          "rules": {
            "memory": "интенсивность < 0.3, преобладают нейтральные или лёгкие эмоции",
            "emotion": "интенсивность ≥ 0.6, преобладают страх, стыд, гнев, грусть",
            "anticipation": "интенсивность 0.4–0.6, эмоции активного ожидания, волнения"
          },
          "weight": 0.33
        },
  
        "action_axis": {
          "title": "Действие",
          "description": "Анализирует, насколько активно сновидец участвует в событиях сна.",
          "indicators": {
            "memory": ["наблюдает", "вспоминает", "беседует", "наблюдает из стороны"],
            "emotion": ["убегает", "прячется", "плачет", "защищается", "сопротивляется"],
            "anticipation": ["готовится", "решает задачу", "борется", "летит", "исследует"]
          },
          "rules": {
            "activity_score": "доля активных глаголов от всех глаголов в тексте"
          },
          "weight": 0.34
        }
      },
  
      "classification_formula": {
        "memory_score": "(context_memory + emotion_memory + action_memory) / 3",
        "emotion_score": "(context_emotion + emotion_emotion + action_emotion) / 3",
        "anticipation_score": "(context_anticipation + emotion_anticipation + action_anticipation) / 3",
        "final_type": "наибольший из трёх баллов (0–1 диапазон)",
        "confidence": "разница между лидером и вторым типом"
      },
  
      "output_example": {
