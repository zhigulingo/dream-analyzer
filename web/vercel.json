{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "ignoreBuildStep": "git diff --quiet HEAD^ HEAD .",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dream-analyzer-seven.vercel.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}