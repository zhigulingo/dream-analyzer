{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "includeFiles": "functions/**,api-internal-shared/**"
    }
  },
  "rewrites": [
    {
      "source": "/bot",
      "destination": "/api/webhook"
    },
    {
      "source": "/api/set-webhook",
      "destination": "/api/webhook"
    },
    {
      "source": "/api/health",
      "destination": "/api/webhook"
    },
    {
      "source": "/",
      "destination": "/api/webhook"
    }
  ]
}