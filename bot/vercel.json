{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "lib/**"
    }
  },
  "rewrites": [
    {
      "source": "/bot",
      "destination": "/api"
    },
    {
      "source": "/api/set-webhook",
      "destination": "/api"
    },
    {
      "source": "/api/health",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}