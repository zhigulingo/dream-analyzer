{
  "functions": {
    "api/index.js": {
      "includeFiles": "functions/**"
    }
  },
  "rewrites": [
    {
      "source": "/bot",
      "destination": "/api/index.js"
    },
    {
      "source": "/api",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    }
  ]
}