        "emotion": 0.68,
        "anticipation": 0.45,
        "dominant_type": "Эмоция",
        "confidence": 0.23
      },
  
      "user_feedback_prompt": "Ты можешь подтвердить: этот сон больше про воспоминания, эмоции или предвосхищение будущего?",
