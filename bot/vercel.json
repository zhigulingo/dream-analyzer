{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "{functions,api-internal-shared}/**"
    }
  },
  "rewrites": [
    {
      "source": "/bot",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/api/index.js"
    }
  ]
}